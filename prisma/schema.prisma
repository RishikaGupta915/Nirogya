// Prisma schema for Supabase (PostgreSQL)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  schemas    = ["public"]
}

model Profile {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uid            String      @unique @db.Uuid
  name           String?     @db.Text
  email          String?     @db.Text
  language       String?     @db.Text
  city           String?     @db.Text
  ageGroup       String?     @map("age_group") @db.Text
  lifeStage      String?     @map("life_stage") @db.Text
  activityLevel  String?     @map("activity_level") @db.Text
  dietType       String?     @map("diet_type") @db.Text
  conditions     String[]    @default([]) @db.Text
  familyHistory  String[]    @map("family_history") @default([]) @db.Text
  medications    String?     @db.Text
  allergies      String[]    @default([]) @db.Text
  sleepHours     Decimal?    @map("sleep_hours") @db.Decimal(4, 1)
  sleepQuality   String[]    @map("sleep_quality") @default([]) @db.Text
  stressLevel    String?     @map("stress_level") @db.Text
  moodSwings     Boolean?    @map("mood_swings")
  anxiety        Boolean?
  lowMotivation  Boolean?    @map("low_motivation")
  lastActiveAt   DateTime?   @map("last_active_at") @db.Timestamptz
  deletedAt      DateTime?   @map("deleted_at") @db.Timestamptz
  createdAt      DateTime    @map("created_at") @default(now()) @db.Timestamptz
  updatedAt      DateTime    @map("updated_at") @default(now()) @updatedAt @db.Timestamptz

  assessments    Assessment[]
  shareLinks     ShareLink[]
  overallShareLinks OverallShareLink[]
  geneticProfile GeneticProfile?
  geneticFlags   GeneticFlag[]

  @@index([uid], map: "idx_profiles_uid")
  @@schema("public")
  @@map("profiles")
}

model Assessment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uid        String   @db.Uuid
  symptom    String?  @db.Text
  answers    Json?
  diagnosis  String?  @db.Text
  riskScore  Int?     @map("riskscore")
  riskLevel  String?  @map("risklevel") @db.Text
  nextSteps  String[] @map("nextsteps") @db.Text
  rawAiText  String?  @map("rawaitext") @db.Text
  createdAt  DateTime? @map("created_at") @default(now()) @db.Timestamptz
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz

  profile    Profile? @relation(fields: [uid], references: [uid], onDelete: Cascade, onUpdate: NoAction)
  shareLinks ShareLink[]

  @@index([uid, createdAt(sort: Desc)], map: "idx_assessments_uid_created_at")
  @@schema("public")
  @@map("assessments")
}

model ShareLink {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uid         String     @db.Uuid
  assessmentId String    @map("assessment_id") @db.Uuid
  tokenHash   String     @unique @map("token_hash") @db.Text
  createdAt   DateTime   @map("created_at") @default(now()) @db.Timestamptz
  expiresAt   DateTime   @map("expires_at") @db.Timestamptz
  revokedAt   DateTime?  @map("revoked_at") @db.Timestamptz
  lastViewedAt DateTime? @map("last_viewed_at") @db.Timestamptz
  viewCount   Int        @map("view_count") @default(0)

  profile     Profile    @relation(fields: [uid], references: [uid], onDelete: Cascade, onUpdate: NoAction)
  assessment  Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([uid, createdAt(sort: Desc)], map: "idx_share_links_uid_created_at")
  @@index([assessmentId], map: "idx_share_links_assessment_id")
  @@index([expiresAt], map: "idx_share_links_expires_at")
  @@schema("public")
  @@map("share_links")
}

model OverallShareLink {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uid          String    @db.Uuid
  tokenHash    String    @unique @map("token_hash") @db.Text
  report       Json
  createdAt    DateTime  @map("created_at") @default(now()) @db.Timestamptz
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz
  lastViewedAt DateTime? @map("last_viewed_at") @db.Timestamptz
  viewCount    Int       @map("view_count") @default(0)

  profile      Profile   @relation(fields: [uid], references: [uid], onDelete: Cascade, onUpdate: NoAction)

  @@index([uid, createdAt(sort: Desc)], map: "idx_overall_share_links_uid_created_at")
  @@index([expiresAt], map: "idx_overall_share_links_expires_at")
  @@schema("public")
  @@map("overall_share_links")
}

model GeneticProfile {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uid       String   @unique @db.Uuid
  rsIds     String[] @map("rs_ids") @db.Text
  prsT2d    Decimal  @map("prs_t2d") @db.Decimal(6, 4)
  prsCad    Decimal  @map("prs_cad") @db.Decimal(6, 4)
  prsHtn    Decimal  @map("prs_htn") @db.Decimal(6, 4)
  createdAt DateTime @map("created_at") @default(now()) @db.Timestamptz
  updatedAt DateTime @map("updated_at") @default(now()) @updatedAt @db.Timestamptz

  profile   Profile       @relation(fields: [uid], references: [uid], onDelete: Cascade, onUpdate: NoAction)
  flags     GeneticFlag[]

  @@index([uid], map: "idx_genetic_profiles_uid")
  @@schema("public")
  @@map("genetic_profiles")
}

model GeneticFlag {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uid            String   @db.Uuid
  geneticProfileId String @map("genetic_profile_id") @db.Uuid
  type           String   @db.Text
  gene           String?  @db.Text
  severity       String   @db.Text
  conditions     String[] @default([]) @db.Text
  plainLanguage  String   @map("plain_language") @db.Text
  actionRequired String   @map("action_required") @db.Text
  drugWarning    String?  @map("drug_warning") @db.Text
  source         String   @db.Text
  createdAt      DateTime @map("created_at") @default(now()) @db.Timestamptz

  profile        Profile        @relation(fields: [uid], references: [uid], onDelete: Cascade, onUpdate: NoAction)
  geneticProfile GeneticProfile @relation(fields: [geneticProfileId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([uid, severity], map: "idx_genetic_flags_uid_severity")
  @@index([geneticProfileId], map: "idx_genetic_flags_profile_id")
  @@schema("public")
  @@map("genetic_flags")
}
