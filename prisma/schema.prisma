// Prisma schema for Supabase (PostgreSQL)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  schemas    = ["public"]
}

model Profile {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uid            String      @unique @db.Uuid
  name           String?     @db.Text
  email          String?     @db.Text
  language       String?     @db.Text
  city           String?     @db.Text
  ageGroup       String?     @map("age_group") @db.Text
  lifeStage      String?     @map("life_stage") @db.Text
  activityLevel  String?     @map("activity_level") @db.Text
  dietType       String?     @map("diet_type") @db.Text
  conditions     String[]    @default([]) @db.Text
  familyHistory  String[]    @map("family_history") @default([]) @db.Text
  medications    String?     @db.Text
  allergies      String[]    @default([]) @db.Text
  sleepHours     Decimal?    @map("sleep_hours") @db.Decimal(4, 1)
  sleepQuality   String[]    @map("sleep_quality") @default([]) @db.Text
  stressLevel    String?     @map("stress_level") @db.Text
  moodSwings     Boolean?    @map("mood_swings")
  anxiety        Boolean?
  lowMotivation  Boolean?    @map("low_motivation")
  lastActiveAt   DateTime?   @map("last_active_at") @db.Timestamptz
  deletedAt      DateTime?   @map("deleted_at") @db.Timestamptz
  createdAt      DateTime    @map("created_at") @default(now()) @db.Timestamptz
  updatedAt      DateTime    @map("updated_at") @default(now()) @updatedAt @db.Timestamptz

  assessments    Assessment[]

  @@index([uid], map: "idx_profiles_uid")
  @@schema("public")
  @@map("profiles")
}

model Assessment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uid        String   @db.Uuid
  symptom    String?  @db.Text
  answers    Json?
  diagnosis  String?  @db.Text
  riskScore  Int?     @map("riskscore")
  riskLevel  String?  @map("risklevel") @db.Text
  nextSteps  String[] @map("nextsteps") @db.Text
  rawAiText  String?  @map("rawaitext") @db.Text
  createdAt  DateTime? @map("created_at") @default(now()) @db.Timestamptz
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz

  profile    Profile? @relation(fields: [uid], references: [uid], onDelete: Cascade, onUpdate: NoAction)

  @@index([uid, createdAt(sort: Desc)], map: "idx_assessments_uid_created_at")
  @@schema("public")
  @@map("assessments")
}
